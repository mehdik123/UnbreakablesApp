# Supabase (required for production - add these in Vercel Project → Settings → Environment Variables)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: coach login (defaults: coach / coach123)
# VITE_COACH_USERNAME=coach
# VITE_COACH_PASSWORD=your-secure-password
